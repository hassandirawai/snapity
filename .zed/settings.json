{
  "format_on_save": "on",
  "formatter": {
    "language_server": {
      "name": "eslint"
    }
  },
  "code_actions_on_format": {
    "source.fixAll.eslint": true
  },
  "languages": {
    "Vue": {
      "language_servers": [
        "eslint",
        "volar"
      ],
      "formatter": {
        "language_server": {
          "name": "eslint"
        }
      }
    },
    "TypeScript": {
      "language_servers": [
        "eslint",
        "typescript-language-server"
      ],
      "formatter": {
        "language_server": {
          "name": "eslint"
        }
      }
    },
    "JavaScript": {
      "language_servers": [
        "eslint",
        "typescript-language-server"
      ],
      "formatter": {
        "language_server": {
          "name": "eslint"
        }
      }
    }
  }
}
